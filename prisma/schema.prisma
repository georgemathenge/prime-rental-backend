generator client {
  provider     = "prisma-client-js"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum UserRole {
  SUPER_ADMIN // You (the developer)
  OWNER // The Landlord
  MANAGER // Property Manager/Staff
  TENANT // The Tenant (for their portal)
}

enum LeaseStatus {
  PENDING_ONBOARDING
  ACTIVE
  EXPIRED
  TERMINATED
}

enum MatchStatus {
  PENDING
  MATCHED
  MANUAL_INTERVENTION
  FLAGGED
  OVER_PAYMENT
}

enum PaymentType {
  RENT
  SERVICE_CHARGE
  DEPOSIT
  UTILITY
}

enum ArrangementStatus {
  ACTIVE
  FULFILLED
  BROKEN
}

enum HouseStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

// --- AUTHENTICATION & USERS ---

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String // Hashed password
  fullName String
  role     UserRole @default(OWNER)
  isActive Boolean  @default(true)

  // Relations to track who created what
  createdProperties Property[]
  createdPayments   Payment[]
  createdLeases     Lease[]

  // Link to Tenant record if the user is a tenant
  tenantProfile Tenant? @relation(fields: [tenantId], references: [id])
  tenantId      String? @unique

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  invoices  Invoice[]
  auditLogs AuditLog[]
}

// --- CORE STRUCTURE ---

model Property {
  id               String            @id @default(uuid())
  name             String            @unique
  bankAccount      String?
  houses           House[]
  bankTransactions BankTransaction[]

  // Audit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
}

model House {
  id             String               @id @default(uuid())
  houseCode      String
  monthlyRent    Decimal              @db.Decimal(12, 2)
  depositAmount  Decimal              @db.Decimal(12, 2)
  propertyId     String
  property       Property             @relation(fields: [propertyId], references: [id])
  lease          Lease[]
  payments       Payment[]
  arrangements   PaymentArrangement[]
  status         HouseStatus          @default(AVAILABLE)
  isActive       Boolean              @default(true)
  currentBalance Decimal              @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@unique([propertyId, houseCode])
}

// --- IDENTITY & LEARNING ---

model Tenant {
  id           String  @id @default(uuid())
  fullName     String
  primaryPhone String  @unique
  email        String?
  lease        Lease[] // ← history lives here

  knownPayers KnownPayer[]
  isActive    Boolean      @default(true)

  // Link back to User for login
  user User?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bankTransactions BankTransaction[]
}

model KnownPayer {
  id         String  @id @default(uuid())
  phone      String
  name       String?
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  propertyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, tenantId])
}

// --- DIGITAL LEASE VAULT ---

model Lease {
  id              String      @id @default(uuid())
  houseId         String
  house           House       @relation(fields: [houseId], references: [id])
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  pdfUrl          String
  startDate       DateTime    @default(now())
  endDate         DateTime?
  status          LeaseStatus @default(PENDING_ONBOARDING)
  isCounterSigned Boolean     @default(false)

  // Audit
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String
  invoices    Invoice[]
}

// --- RECONCILIATION ENGINE ---

model BankTransaction {
  id              String      @id @default(uuid())
  bankReference   String      @unique
  amount          Decimal     @db.Decimal(12, 2)
  transactionDate DateTime
  narrative       String
  payerPhone      String?
  status          MatchStatus @default(PENDING)
  matchLevel      Int?
  matchNote       String? // ← reason for manual intervention
  tenantId        String? // ← store matched tenant for context
  tenant          Tenant?     @relation(fields: [tenantId], references: [id])
  payments        Payment[]
  propertyId      String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  property        Property    @relation(fields: [propertyId], references: [id])
}

model Payment {
  id                String           @id @default(uuid())
  houseId           String
  house             House            @relation(fields: [houseId], references: [id])
  bankTransactionId String?
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  amount            Decimal          @db.Decimal(12, 2)
  datePaid          DateTime         @default(now())
  type              PaymentType      @default(RENT)
  note              String?

  // Audit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  invoiceId   String?
}

model PaymentArrangement {
  id          String            @id @default(uuid())
  houseId     String
  house       House             @relation(fields: [houseId], references: [id])
  promiseDate DateTime
  reason      String?
  status      ArrangementStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique // e.g INV-2026-001
  houseId       String
  house         House  @relation(fields: [houseId], references: [id])
  leaseId       String
  lease         Lease  @relation(fields: [leaseId], references: [id])

  type   InvoiceType   @default(RENT) // RENT, PENALTY, ARREARS
  status InvoiceStatus @default(UNPAID) // UNPAID, PAID, PARTIAL, OVERDUE

  amount        Decimal  @db.Decimal(12, 2) // base amount
  penaltyAmount Decimal  @default(0) @db.Decimal(12, 2) // penalties added on top
  totalAmount   Decimal  @db.Decimal(12, 2) // amount + penalty
  paidAmount    Decimal  @default(0) @db.Decimal(12, 2) // what has been paid so far
  balanceDue    Decimal  @db.Decimal(12, 2) // totalAmount - paidAmount
  carryOver     Decimal  @default(0) @db.Decimal(12, 2) // arrears from previous period creditAmount Decimal @default(0) @db.Decimal(12, 2) // excess from previous period  excessAmount Decimal @default(0) @db.Decimal(12, 2)
  excessAmount  Decimal  @default(0) @db.Decimal(12, 2) // if paidAmount > totalAmount
  creditAmount  Decimal  @default(0) @db.Decimal(12, 2) // for excess payments that can be applied to future invoices
  dueDate       DateTime
  periodStart   DateTime // e.g 1st March 2026
  periodEnd     DateTime // e.g 31st March 2026
  notes         String?

  payment Payment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
}

enum InvoiceType {
  RENT
  PENALTY
  ARREARS
  DEPOSIT
  OTHER
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum AuditAction {
  // Auth
  USER_LOGIN
  USER_LOGIN_FAILED
  // Users
  USER_CREATED
  USER_UPDATED
  USER_ROLE_CHANGED
  // Houses
  HOUSE_CREATED
  HOUSE_UPDATED
  // Tenants
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_MOVED_OUT
  // Invoices
  INVOICE_CREATED
  INVOICE_UPDATED
  INVOICE_CANCELLED
  // Payments
  BANK_STATEMENT_UPLOADED
  PAYMENT_MANUALLY_ASSIGNED
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String?
  summary   String // human readable e.g. "Created invoice INV-2026-0023 for house A1"
  meta      Json? // extra context e.g. { before: {}, after: {} }
  ip        String?
  createdAt DateTime    @default(now())
}
